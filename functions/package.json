{
  "name": "pdfa2z-notarize-functions",
  "description": "Firebase Functions backend for pdfa2z.com RON (Remote Online Notarization)",
  "scripts": {
    "build": "tsc",
    "serve": "npm run build && firebase emulators:start --only functions",
    "shell": "npm run build && firebase functions:shell",
    "start": "npm run shell",
    "deploy": "npm run build && firebase deploy --only functions",
    "logs": "firebase functions:log"
  },
  "engines": {
    "node": "20"
  },
  "main": "lib/index.js",
  "dependencies": {
    "cors": "^2.8.5",
    "docx": "^9.6.1",
    "exceljs": "^4.4.0",
    "express": "^4.18.2",
    "firebase-admin": "^12.0.0",
    "firebase-functions": "^5.0.0",
    "node-fetch": "^3.3.2",
    "pdf-parse": "^1.1.1",
    "stripe": "^14.0.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.0.0",
    "@types/pdf-parse": "^1.1.4",
    "typescript": "^5.2.2"
  },
  "private": true
}
